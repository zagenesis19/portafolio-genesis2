---
import { Github, Linkedin, Mail, ArrowUpCircle } from 'lucide-astro';
---

<footer class="relative mt-20 md:mt-32 border-t border-white/10 bg-[#040814] pt-16 pb-8 overflow-hidden z-20">
  <!-- Glowing gradient background line -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-2xl h-[1px] bg-gradient-to-r from-transparent via-blue-500 to-transparent opacity-50"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-sm h-[300px] bg-blue-600/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Brand & Bio -->
      <div class="lg:col-span-2">
        <a href="#" class="inline-flex items-center gap-3 mb-4 group">
          <img src="/logo.svg" alt="Génesis Zapata" class="w-12 h-12 object-contain group-hover:scale-110 group-hover:drop-shadow-[0_0_20px_rgba(157,0,255,0.6)] transition-all drop-shadow-[0_0_10px_rgba(0,229,255,0.3)]" />
          <span class="text-xl font-bold text-white tracking-tight group-hover:text-blue-400 transition-colors">Génesis Zapata</span>
        </a>
        <p class="text-slate-400 max-w-sm leading-relaxed mb-6">
          Arquitecta de Soluciones & Fullstack Developer. Apasionada por el código limpio, la eficiencia y el liderazgo en equipos de alto rendimiento para convertir ideas complejas en sistemas reales.
        </p>
        <div class="flex gap-4">
          <a href="https://github.com/zagenesis19" target="_blank" rel="noopener noreferrer" data-astro-reload class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/10 hover:border-white/20 transition-all hover:-translate-y-1" title="GitHub">
            <Github size={20} />
          </a>
          <a href="https://www.linkedin.com/in/g%C3%A9nesis-zapata-990471227/" target="_blank" rel="noopener noreferrer" data-astro-reload class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/10 hover:border-white/20 transition-all hover:-translate-y-1" title="LinkedIn">
            <Linkedin size={20} />
          </a>
          <a href="mailto:zgenesisangelina@gmail.com" data-astro-reload class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/10 hover:border-white/20 transition-all hover:-translate-y-1" title="Email">
            <Mail size={20} />
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-6 uppercase tracking-wider text-sm">Navegación</h3>
        <ul class="space-y-3">
          <li><a href="#proyectos" class="text-slate-400 hover:text-blue-400 transition-colors inline-block">Proyectos</a></li>
          <li><a href="#habilidades" class="text-slate-400 hover:text-blue-400 transition-colors inline-block">Stack Tecnológico</a></li>
          <li><a href="#experiencia" class="text-slate-400 hover:text-blue-400 transition-colors inline-block">Experiencia</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-semibold mb-6 uppercase tracking-wider text-sm">Contacto</h3>
        <ul class="space-y-4">
          <li>
            <a href="mailto:zgenesisangelina@gmail.com" data-astro-reload class="text-slate-300 hover:text-blue-400 transition-colors inline-block relative font-medium group">
              Hablemos de tu proyecto
              <span class="absolute -bottom-1 left-0 w-0 h-[1.5px] bg-blue-400 transition-all group-hover:w-full"></span>
            </a>
          </li>
          <li class="pt-2">
            <div class="inline-flex items-center gap-2 bg-emerald-500/10 text-emerald-400 px-3 py-1.5 rounded-full border border-emerald-500/20 text-xs font-medium uppercase tracking-wider">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
              </span>
              Abierta a ofertas
            </div>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright & Up button -->
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-sm text-center md:text-left">
        © {new Date().getFullYear()} Génesis Zapata. Construido estéticamente con Astro & Tailwind.
      </p>
      
      <a href="#" class="text-slate-500 hover:text-white flex items-center gap-2 text-sm transition-colors group">
        <span>Volver arriba</span>
        <ArrowUpCircle size={18} class="group-hover:-translate-y-1 text-slate-400 group-hover:text-blue-400 transition-all" />
      </a>
    </div>
  </div>
</footer>
