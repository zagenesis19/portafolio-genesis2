---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="proyectos" class="py-24 relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 z-0 bg-[#0a0f1c]"></div>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-violet-600/10 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-cyan-600/8 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-slate-300 text-sm mb-6 backdrop-blur-sm shadow-lg shadow-black/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <span class="font-medium tracking-wide uppercase">Casos de Estudio</span>
      </div>
      <h2 class="text-3xl md:text-5xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-white to-slate-400 mb-4 tracking-tight">
        Proyectos de Ingeniería
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl">
        Cada proyecto es un caso de estudio real: un <span class="text-white font-medium">problema técnico</span>, una <span class="text-cyan-400 font-medium">solución arquitectónica</span>, y un <span class="text-amber-400 font-medium">resultado medible</span>.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          role={project.data.role}
          technologies={project.data.technologies}
          problem={project.data.problem}
          solution={project.data.solution}
          key_achievement={project.data.key_achievement}
          github_url={project.data.github_url}
          demo_url={project.data.demo_url}
          icon={project.data.icon}
          gradient_from={project.data.gradient_from}
          gradient_to={project.data.gradient_to}
          accent_color={project.data.accent_color}
        />
      ))}
    </div>
  </div>
</section>
