---
import { Briefcase, GraduationCap, ChevronRight } from 'lucide-astro';

const experiences = [
  {
    role: "Fullstack Developer & Technical Lead",
    company: "Fibex Telecom",
    period: "Pasante - Presente",
    description: "Desarrollo de soluciones empresariales críticas y automatizaciones. Destacada por mi proactividad y liderazgo en la toma de decisiones técnicas, proponiendo arquitecturas escalables y guiando al equipo multidisciplinario en la implementación de estándares sólidos.",
    icon: Briefcase
  },
  {
    role: "TSU en Informática",
    company: "Universidad de Tecnología Antonio José de Sucre (UTS)",
    period: "Estudiante",
    description: "Formación académica enfocada en algoritmia, diseño de bases de datos, redes y arquitectura de software.",
    icon: GraduationCap
  }
];
---

<section id="experiencia" class="py-24 relative border-t border-white/5 bg-[#0a0f1c]">
  <!-- Background Glow -->
  <div class="absolute left-0 bottom-0 w-[400px] h-[400px] bg-blue-600/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <div class="mb-16 text-center md:text-left">
      <h2 class="text-3xl md:text-5xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-violet-500 mb-4 tracking-tight">
        Experiencia & Formación
      </h2>
      <p class="text-slate-400 text-lg">
        Mi trayectoria profesional y bases académicas.
      </p>
    </div>

    <div class="space-y-12 md:space-y-8">
      {experiences.map((exp, index) => (
        <div class="relative pl-8 md:pl-0">
          <!-- Desktop Layout -->
          <div class="md:grid md:grid-cols-5 md:gap-8 items-start">
            
            <div class="hidden md:block col-span-1 text-right pt-2 text-sm font-bold tracking-wider text-slate-400/80 uppercase">
              {exp.period}
            </div>

            <div class="col-span-4 relative group">
              <!-- Timeline vertical line (Desktop) -->
              <div class={`hidden md:block absolute left-[-26px] top-6 bottom-[-60px] w-[2px] bg-white/10 ${index === experiences.length - 1 ? 'hidden' : ''}`}></div>
              
              <!-- Timeline Node (Desktop) -->
              <div class="absolute hidden md:flex left-[-32px] top-2 w-3.5 h-3.5 rounded-full bg-brand-primary shadow-[0_0_15px_rgba(59,130,246,0.6)] z-10 items-center justify-center"></div>
              
               <!-- Timeline vertical line (Mobile) -->
               <div class={`md:hidden absolute left-[-26px] top-4 bottom-[-60px] w-[2px] bg-white/10 ${index === experiences.length - 1 ? 'hidden' : ''}`}></div>

               <!-- Timeline Node (Mobile) -->
              <div class="md:hidden absolute left-[-31px] top-1 w-3 h-3 rounded-full bg-brand-primary shadow-[0_0_15px_rgba(59,130,246,0.6)] z-10"></div>
              

              <!-- Mobile specific period label -->
              <div class="md:hidden text-xs font-bold text-brand-primary mb-3 tracking-widest uppercase flex items-center gap-2">
                <ChevronRight size={14} />
                {exp.period}
              </div>

              <!-- Card Content -->
              <div class="reveal bg-white/5 border border-white/10 p-6 md:p-8 rounded-2xl hover:bg-white/10 transition-all duration-300 backdrop-blur-sm group-hover:-translate-y-1 group-hover:shadow-2xl group-hover:shadow-blue-900/20">
                <div class="flex items-center gap-3 mb-2">
                  <div class="p-2.5 bg-white/5 rounded-lg border border-white/10 text-brand-primary">
                    <exp.icon size={22} />
                  </div>
                  <h3 class="text-xl md:text-2xl font-bold text-slate-100">{exp.role}</h3>
                </div>
                <h4 class="text-base md:text-lg text-brand-secondary font-medium mb-4 pl-[52px] md:pl-[56px] -mt-2">
                  {exp.company}
                </h4>
                <p class="text-slate-400 leading-relaxed text-sm md:text-base border-t border-white/5 pt-4 mt-2">
                  {exp.description}
                </p>
              </div>
            </div>
            
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
